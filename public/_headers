/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://static.cloudflareinsights.com https://plausible.io; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self' https://api.kindreply.co https://cloudflareinsights.com https://*.cloudflareinsights.com https://plausible.io; frame-ancestors 'none'; base-uri 'self'; form-action 'self';
  Cache-Control: public, max-age=0, must-revalidate, no-cache

/_next/static/*
  Cache-Control: public, max-age=31536000, immutable